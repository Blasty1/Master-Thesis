@article{HABIBI2026114351,
title = {Dynamic wagon assignment and reassignment for pick-up and delivery requests: A deep reinforcement learning framework to address uncertainty in locomotive availability},
journal = {Applied Soft Computing},
volume = {187},
pages = {114351},
year = {2026},
issn = {1568-4946},
doi = {https://doi.org/10.1016/j.asoc.2025.114351},
url = {https://www.sciencedirect.com/science/article/pii/S1568494625016643},
author = {Parivash Habibi and Mohammad Tamannaei and Hamid Zarei},
keywords = {Deep reinforcement learning, Actor-Critic algorithm, Railway freight transportation, Pick-up and delivery, Fleet assignment},
abstract = {We investigate the dynamic assignment of freight wagons within a railway transportation network under uncertainty in locomotive availability. Enhancing railway fleet efficiency depends on minimizing the movement of empty wagons and reducing delays in freight delivery. Therefore, a dynamic multi-period planning model is developed to prioritize pick-up and delivery requests and to assign and reassign wagons for freight transportation over a specific planning horizon, given a limited number of railway fleet. The model accounts for real-world operational constraints and uncertainty, to ensure fulfillment of delivery commitments and reduce delays and operational costs. To address uncertainty in the model, a learning-based methodology is proposed aiming to enhance the railway fleet efficiency. To solve the model in a discrete environment, we propose a Deep Reinforcement Learning (DRL) framework, based on two algorithms, i.e. the Actor-Critic and Proximal Policy Optimization(PPO), which is integrated by heuristic assignment and reassignment rules. The framework combines the advantages of real-time response with adaptability of the neural networks. In order to validate the effectiveness of the proposed DRL framework, the results are compared with two benchmark methods: a dynamic Simulated Annealing algorithm and the Eisenhower decision matrix. The comparisons demonstrate the superior performance of the proposed DRL framework in terms of cumulative reward for the railway operator as the decision maker. Furthermore, four performance metrics are developed to provide a comprehensive evaluation for service quality and operational efficiency. It is also deduced that although the model formulation is customized within a railway transportation mode, the proposed framework is inherently general and transferable across other transportation modes.}
}

